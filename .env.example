# ─── Frontend (Vite) ─────────────────────────────────────
# Backend API URL for scheduling
VITE_API_URL=http://localhost:3001

# ─── API Server ──────────────────────────────────────────
# Port for the API server (default: 3001)
PORT=3001

# IANA timezone for business hours (default: America/Bogota)
BUSINESS_TIMEZONE=America/Bogota

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:8080,https://heysquai.vercel.app

# ─── Google Calendar ─────────────────────────────────────
# Service Account key JSON (single-line, paste the full JSON)
GOOGLE_SERVICE_ACCOUNT_KEY=

# Calendar ID (usually your-email@gmail.com or a specific calendar ID)
GOOGLE_CALENDAR_ID=

# ─── Google OAuth (recommended for attendee invites) ─────
# OAuth client credentials from Google Auth Platform -> Clients
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Refresh token obtained after completing /api/oauth/google/start flow
GOOGLE_OAUTH_REFRESH_TOKEN=

# Public base URL used to build OAuth callback URL
# Local: http://localhost:3001
GOOGLE_OAUTH_REDIRECT_BASE_URL=http://localhost:3001

# Secret used to sign/validate OAuth state parameter
GOOGLE_OAUTH_STATE_SECRET=

# Base URL for reschedule deeplink (landing will open modal using query params)
# Example: http://localhost:8080/en
BOOKING_RESCHEDULE_URL=
