{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist/server",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "typeRoots": ["../node_modules/@types"],
    "resolveJsonModule": true,
    "declaration": true,
    "isolatedModules": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["dist"]
}
